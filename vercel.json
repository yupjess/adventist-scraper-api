{
  "version": 2,
  "routes": [
    {
      "src": "/",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/directory/privacy/policy",
      "dest": "/api/directory/privacy/policy.js"
    },
    {
      "src": "/api/directory/health",
      "dest": "/api/directory/health.js"
    },
    {
      "src": "/api/directory/scrape",
      "dest": "/api/directory/scrape.js"
    },
    {
      "src": "/api/directory/search",
      "dest": "/api/directory/search.js"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
